// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  ACTIVE
  SHIPPED
  IN_DESIGN
  PLANNED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DispatchStatus {
  DRAFT
  SCHEDULED
  SENT
  ARCHIVED
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

enum ReadmeThemeVariant {
  SYSTEM
  CYAN_VIOLET
  MINIMAL
}

enum MediaAssetType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum ContactMessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

model Project {
  id                  String              @id @default(cuid())
  title               String
  slug                String              @unique
  summary             String
  description         String              @db.Text
  status              ProjectStatus       @default(PLANNED)
  category            String?
  featured            Boolean             @default(false)
  coverImage          String?
  repoUrl             String?
  liveUrl             String?
  sortOrder           Int                 @default(0)
  publishedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  readmeSettings      ReadmeSettings[]
  projectTechnologies ProjectTechnology[]
  mediaAssets         MediaAsset[]

  @@index([status, sortOrder])
  @@index([featured, publishedAt])
}

model BlogPost {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  excerpt      String
  content      String        @db.Text
  coverImage   String?
  featured     Boolean       @default(false)
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  readTime     Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  blogPostTags BlogPostTag[]
  mediaAssets  MediaAsset[]

  @@index([status, publishedAt])
  @@index([featured, publishedAt])
}

model DispatchIssue {
  id          String         @id @default(cuid())
  title       String
  subject     String
  excerpt     String
  content     String         @db.Text
  status      DispatchStatus @default(DRAFT)
  publishedAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, publishedAt])
}

model Subscriber {
  id        String           @id @default(cuid())
  email     String           @unique
  status    SubscriberStatus @default(PENDING)
  source    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
}

model CurrentStatus {
  id                String   @id @default("main")
  currentFocus      String
  currentlyBuilding String[] @default([])
  currentlyLearning String[] @default([])
  currentGoal       String
  updatedAt         DateTime @updatedAt
}

model ReadmeSettings {
  id                String             @id @default("default")
  featuredProjectId String?
  showLatestPosts   Boolean            @default(true)
  latestPostsCount  Int                @default(3)
  showStatusCard    Boolean            @default(true)
  themeVariant      ReadmeThemeVariant @default(SYSTEM)
  updatedAt         DateTime           @updatedAt

  featuredProject  Project? @relation(fields: [featuredProjectId], references: [id], onDelete: SetNull)

  @@index([featuredProjectId])
}

model Tag {
  id           String        @id @default(cuid())
  name         String        @unique
  slug         String        @unique
  createdAt    DateTime      @default(now())
  blogPostTags BlogPostTag[]
}

model BlogPostTag {
  id         String   @id @default(cuid())
  blogPostId String
  tagId      String
  createdAt  DateTime @default(now())

  blogPost BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, tagId])
  @@index([tagId])
}

model Technology {
  id                  String              @id @default(cuid())
  name                String              @unique
  slug                String              @unique
  icon                String?
  websiteUrl          String?
  createdAt           DateTime            @default(now())
  projectTechnologies ProjectTechnology[]
}

model ProjectTechnology {
  id           String   @id @default(cuid())
  projectId    String
  technologyId String
  createdAt    DateTime @default(now())

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@unique([projectId, technologyId])
  @@index([technologyId])
}

model MediaAsset {
  id         String         @id @default(cuid())
  url        String
  alt        String?
  caption    String?
  type       MediaAssetType @default(IMAGE)
  width      Int?
  height     Int?
  sortOrder  Int            @default(0)
  projectId  String?
  blogPostId String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blogPost BlogPost? @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
  @@index([blogPostId, sortOrder])
}

model SiteSettings {
  id             String   @id @default("default")
  siteTitle      String
  siteDescription String
  siteUrl        String?
  logoUrl        String?
  contactEmail   String?
  seoTitle       String?
  seoDescription String?
  updatedAt      DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  label     String
  url       String
  icon      String?
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, sortOrder])
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String               @db.Text
  status    ContactMessageStatus @default(UNREAD)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorLabel String?
  actorEmail String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
